{
    "id": "7887a1af",
    "name": "ComfyUI Connector",
    "version": "1.1.0",
    "main": "index.html",
    "manifestVersion": 6,
    "host": {
        "app": "PS",
        "minVersion": "23.0.0"
    },
    "entrypoints": [
        {
            "type": "panel",
            "id": "comfyui.connector.panel",
            "label": {
                "default": "ComfyUI Connector"
            },
            "minimumSize": {
                "width": 240,
                "height": 120
            },
            "maximumSize": {
                "width": 1200,
                "height": 2000
            },
            "preferredDockedSize": {
                "width": 280,
                "height": 500
            },
            "preferredFloatingSize": {
                "width": 300,
                "height": 550
            },
            "icons": [
                {
                    "width": 23,
                    "height": 23,
                    "path": "icons/icon_23.png",
                    "scale": [1],
                    "theme": ["all"],
                    "species": ["pluginList"]
                },
                {
                    "width": 23,
                    "height": 23,
                    "path": "icons/icon_23@2x.png",
                    "scale": [2],
                    "theme": ["all"],
                    "species": ["pluginList"]
                }
            ]
        }
    ],
    "requiredPermissions": {
        "localFileSystem": "fullAccess",
        "network": {
            "domains": "all"
        },
        "clipboard": "readAndWrite",
        "allowCodeGenerationFromStrings": true
    },
    "icons": [
        {
            "width": 23,
            "height": 23,
            "path": "icons/icon_23.png",
            "scale": [1],
            "theme": ["all"],
            "species": ["pluginList"]
        },
